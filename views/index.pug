extends layout

block content

  // HOME PAGE
  if page == 'home'
    section.hero
      h1 Fresh Donuts Daily
      p Family-owned, made fresh, since 1992
      a.button(href='/menu') View Menu

  // MENU PAGE
  if page == 'menu'
    h1 Our Menu

    h2 Signature Donuts
    ul.menu
      li Classic Glazed — $2.50
      li Maple Bacon Bar — $3.75
      li Boston Cream — $3.50
      li Blueberry Cake — $3.25
      li Cinnamon Sugar Twist — $2.75
      li Strawberry Frosted — $3.00
      li Chocolate Old Fashioned — $3.25
      li Lemon Poppy Seed — $3.50
      li Dulce de Leche — $3.75
      li PB & J — $3.75

    h3 Donut Holes
    p Half Dozen — $4.50 | Dozen — $7.99

    h2 Coffee
    ul.menu
      li Drip Coffee — $2.25 / $2.75 / $3.25
      li Cold Brew — $3.50 / $4.00 / $4.50
      li Espresso — $3.00
      li Americano — $3.25 / $3.75 / $4.25
      li Latte — $4.25 / $4.75 / $5.25
      li Cappuccino — $4.25 / $4.75 / $5.25
      li Mocha — $4.75 / $5.25 / $5.75
      li Vanilla Chai Latte — $4.50 / $5.00 / $5.50

    h3 Add-ons
    p Extra shot +$0.75 | Syrup +$0.50 | Alt milk +$0.60

    h2 Other Drinks
    ul.menu
      li Fresh Squeezed OJ — $3.50
      li Hot Chocolate — $3.75
      li Iced Tea — $2.50
      li Lemonade — $2.75
      li Milk — $2.00
      li Apple Cider — $3.50

    h2 Breakfast Bites
    ul.menu
      li Egg & Cheese Croissant — $5.50
      li Bacon Breakfast Sandwich — $6.25
      li Avocado Toast — $5.75
      li Yogurt Parfait — $4.50

    h2 Order Online
    a.button(href='https://ubereats.com') UberEats
    a.button(href='https://doordash.com') DoorDash

  // ABOUT PAGE
  if page == 'about'
    h1 About Us
    p Downtown Donuts is a family-owned shop serving the community since 1992.
    p We specialize in fresh donuts, great coffee, and a friendly environment.

  // COMMENTS PAGE
  if page == 'comments'
    h1 Customer Reviews

    if error
      p(style="color:red")= error

    form(method='POST' action='/add-comment').comment-form
      div.form-group
        label(for='comment') Reviews & comments:
        textarea(name='task' id='comment' required)
      button(type='submit' onclick="this.disabled=true; this.form.submit();") Post Comment

    each val in todos
      article.comment
        p= val.task
        small Posted: #{val.formattedTime}
    
        form(method='POST' action='/delete-comment')
          input(type='hidden' name='id' value=val.id)
          button.delete-btn(type='submit') Delete
      
    div.pagination
      if currentPage > 1
        a(href=`/comments?p=${currentPage - 1}`) Prev

      a(href=`/comments?p=${currentPage + 1}`) Next